{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlazeClaw Baidu Search Tool Contracts",
  "version": "1.0.0",
  "contracts": {
    "baidu-search.search.web": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query"
      ],
      "properties": {
        "query": {
          "type": "string",
          "minLength": 1,
          "description": "Search query text."
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum number of search results to return."
        },
        "freshness": {
          "type": "string",
          "description": "Time range filter: pd/pw/pm/py or YYYY-MM-DDtoYYYY-MM-DD"
        }
      }
    }
  }
}
