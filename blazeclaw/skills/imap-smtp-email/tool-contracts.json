{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlazeClaw IMAP/SMTP Email Tool Contracts",
  "version": "1.0.0",
  "contracts": {
    "imap_smtp_email.imap.check": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+$"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200
        },
        "mailbox": {
          "type": "string",
          "minLength": 1
        },
        "recent": {
          "type": "string",
          "pattern": "^[0-9]+[mhd]$"
        },
        "unseen": { "type": "boolean" }
      }
    },
    "imap_smtp_email.imap.fetch": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "uid" ],
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+$"
        },
        "uid": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "integer",
              "minimum": 1
            }
          ]
        },
        "mailbox": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "imap_smtp_email.imap.download": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "uid" ],
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+$"
        },
        "uid": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "integer",
              "minimum": 1
            }
          ]
        },
        "mailbox": {
          "type": "string",
          "minLength": 1
        },
        "dir": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "imap_smtp_email.imap.search": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+$"
        },
        "unseen": { "type": "boolean" },
        "seen": { "type": "boolean" },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "recent": {
          "type": "string",
          "pattern": "^[0-9]+[mhd]$"
        },
        "since": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "before": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200
        },
        "mailbox": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "imap_smtp_email.imap.mark_read": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "uids" ],
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+$"
        },
        "mailbox": {
          "type": "string",
          "minLength": 1
        },
        "uids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "integer",
                "minimum": 1
              }
            ]
          }
        }
      }
    },
    "imap_smtp_email.imap.mark_unread": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "uids" ],
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+$"
        },
        "mailbox": {
          "type": "string",
          "minLength": 1
        },
        "uids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "integer",
                "minimum": 1
              }
            ]
          }
        }
      }
    },
    "imap_smtp_email.imap.list_mailboxes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+$"
        }
      }
    },
    "imap_smtp_email.imap.list_accounts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "imap_smtp_email.smtp.send": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "to" ],
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+$"
        },
        "to": {
          "type": "string",
          "minLength": 3
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "subjectFile": {
          "type": "string",
          "minLength": 1
        },
        "body": { "type": "string" },
        "bodyFile": {
          "type": "string",
          "minLength": 1
        },
        "html": { "type": "boolean" },
        "htmlFile": {
          "type": "string",
          "minLength": 1
        },
        "cc": { "type": "string" },
        "bcc": { "type": "string" },
        "attach": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "from": {
          "type": "string",
          "minLength": 3
        }
      },
      "anyOf": [
        { "required": [ "subject" ] },
        { "required": [ "subjectFile" ] }
      ]
    },
    "imap_smtp_email.smtp.test": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+$"
        }
      }
    },
    "imap_smtp_email.smtp.list_accounts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    }
  }
}
