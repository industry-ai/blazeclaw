{
  "id": "ops-tools",
  "name": "Operational Tools",
  "description": "Concrete weather lookup and approval-gated email scheduling tools.",
  "version": 1,
  "kind": "tools",
  "tools": [
    {
      "id": "weather.lookup",
      "label": "Weather Lookup",
      "category": "data",
      "enabled": true
    },
    {
      "id": "email.schedule",
      "label": "Email Schedule",
      "category": "communication",
      "enabled": true
    }
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "weatherProvider": {
        "type": "string",
        "description": "Weather backend provider identifier.",
        "default": "blazeclaw.weather.provider.v1"
      },
      "emailScheduler": {
        "type": "string",
        "description": "Email scheduling backend identifier.",
        "default": "blazeclaw.email.scheduler.backend.v1"
      },
      "approvalTokenMaxAgeMinutes": {
        "type": "integer",
        "minimum": 1,
        "maximum": 1440,
        "default": 60,
        "description": "Approval token TTL for outbound email scheduling."
      }
    }
  }
}
