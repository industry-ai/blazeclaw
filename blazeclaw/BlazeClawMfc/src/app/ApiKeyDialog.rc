#include "resource.h"

IDD_APIKEY_DIALOG DIALOGEX 0, 0, 260, 80
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "DeepSeek API Key"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "API Key:", IDC_STATIC_APIKEY_LABEL, 10, 14, 40, 10
    EDITTEXT        IDC_EDIT_APIKEY, 56, 12, 190, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK", IDOK, 96, 42, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 152, 42, 50, 14
END
